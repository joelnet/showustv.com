{
  "name": "showustv",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.worker.json && tsc --noEmit -p tsconfig.web.json",
    "dev": "npm run build && wrangler dev --ip 0.0.0.0",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "db:migrate:local": "wrangler d1 migrations apply showustv --local",
    "db:migrate:remote": "wrangler d1 migrations apply showustv --remote",
    "admin": "node scripts/admin.mjs",
    "generate:landing-screenshots": "node scripts/prepare-landing-screenshots.mjs",
    "generate:poster-wall": "node scripts/generate-poster-wall.mjs"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "@sigma/node-image": "^3.0.0",
    "fflate": "^0.8.3",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "hono": "^4.8.0",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "sigma": "^3.0.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.5.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wrangler": "^4.106.0"
  }
}
